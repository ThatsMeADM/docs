{
  "theme": "mint",
  "$schema": "https://mintlify.com/docs.json",
  "name": "That's Me Docs",
  "colors": {
    "primary": "#D4A017",
    "light": "#F9F5F2",
    "dark": "#1E2025"
  },
  "fonts": {
    "family": "Helvetica Now Display",
    "source": "/fonts/HelveticaNowDisplay-Medium.woff2",
    "format": "woff2",
    "weight": 500,
    "heading": {
      "family": "Helvetica Now Display",
      "source": "/fonts/HelveticaNowDisplay-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "Helvetica Now Display",
      "source": "/fonts/HelveticaNowDisplay-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "styles": {
    "global": "/styles.css"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "api": {
    "mdx": {
      "auth": {
        "method": "bearer"
      },
      "server": "https://api.thatsme.com.br"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "mailto:suporte@thatsme.com.br"
      }
    ]
  },
  "tabs": [
    { "name": "Platform", "url": "platform" },
    { "name": "For Issuers", "url": "for-issuers" },
    { "name": "API Reference", "url": "api/v1" },
    { "name": "Public API", "url": "public-api" },
    { "name": "Automations", "url": "automations" },
    { "name": "Changelog", "url": "changelog" }
  ],
  "navigation": [
    {
      "group": "Platform",
      "pages": ["platform/welcome", "platform/how-it-works", "platform/verification", "platform/plans"]
    },
    {
      "group": "For Issuers",
      "pages": ["for-issuers/quickstart", "for-issuers/recommendation-guide"]
    },
    {
      "group": "API Overview",
      "pages": ["api/v1/overview", "api/v1/quickstart"]
    },
    {
      "group": "Webhooks",
      "pages": ["api/v1/webhooks/overview", "api/v1/webhooks/verify-signature", "api/v1/webhooks/events"]
    },
    {
      "group": "Public API",
      "pages": ["public-api/overview"]
    },
    {
      "group": "Automations",
      "pages": ["automations/overview", "automations/n8n/emit-from-spreadsheet", "automations/mcp/overview", "automations/use-cases/marathon"]
    },
    {
      "group": "Changelog",
      "pages": ["changelog/index"]
    }
  ],
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/app.thatsme/",
      "linkedin": "https://www.linkedin.com/company/that-sme/",
      "website": "https://www.thatsme.com.br/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
