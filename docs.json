{
  "theme": "mint",
  "$schema": "https://mintlify.com/docs.json",
  "name": "That's Me Docs",
  "colors": {
    "primary": "#D4A017",
    "light": "#F9F5F2",
    "dark": "#1E2025"
  },
  "fonts": {
    "heading": {
      "family": "Helvetica Now Display",
      "source": "https://app.thatsme.com.br/fonts/HelveticaNow/HelveticaNowDisplay-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "Helvetica Now Display",
      "source": "https://app.thatsme.com.br/fonts/HelveticaNow/HelveticaNowDisplay-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "styles": {
    "global": "/styles.css"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "api": {
    "mdx": {
      "auth": {
        "method": "bearer"
      },
      "server": "https://api.thatsme.com.br"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "mailto:suporte@thatsme.com.br"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Platform",
            "pages": ["platform/welcome", "platform/how-it-works", "platform/verification", "platform/certificate-permanence", "platform/plans"]
          },
          {
            "group": "Plans & Billing",
            "pages": ["plans/overview", "plans/overage", "plans/whatsapp", "plans/sla"]
          }
        ]
      },
      {
        "tab": "For Issuers",
        "groups": [
          {
            "group": "For Issuers",
            "pages": ["for-issuers/quickstart", "for-issuers/recommendation-guide"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Overview",
            "pages": ["api/v1/overview", "api/v1/quickstart", "api/v1/tiers"]
          },
          {
            "group": "Webhooks",
            "pages": ["api/v1/webhooks/overview", "api/v1/webhooks/verify-signature", "api/v1/webhooks/events"]
          }
        ]
      },
      {
        "tab": "Public API",
        "groups": [
          {
            "group": "Public API",
            "pages": ["public-api/overview"]
          }
        ]
      },
      {
        "tab": "Automations",
        "groups": [
          {
            "group": "Automations",
            "pages": ["automations/overview", "automations/n8n/emit-from-spreadsheet", "automations/mcp/overview", "automations/use-cases/marathon"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": ["changelog/index"]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/app.thatsme/",
      "linkedin": "https://www.linkedin.com/company/that-sme/",
      "website": "https://www.thatsme.com.br/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
